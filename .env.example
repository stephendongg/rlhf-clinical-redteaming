# Copy this file to .env and fill in your values
# $ cp .env.example .env

# OpenAI API key — used only by the GPT-4o-mini judge.
OPENAI_API_KEY=sk-...

# GCS bucket root where per-run artifacts are synced.
# Per-method subfolders are created automatically: <bucket>/{baseline,dpo,ppo}/<run-uuid>/
GCS_BUCKET=gs://results_043026

# Optional: HF token for gated models (Qwen / BioMistral are public, so usually unset).
# HF_TOKEN=hf_...
